# GigaChat (основной LLM)
# Получить ключ: https://developers.sber.ru/studio/workspaces
# Authorization Key = base64(Client ID:Client Secret) с панели разработчика
GIGACHAT_API_KEY=PASTE_BASE64_AUTHORIZATION_KEY_HERE
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# В API имя модели «Lite» = "GigaChat" (без суффикса). Другие: GigaChat-Pro, GigaChat-Max, GigaChat-2.
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=false

# Резервные LLM (опционально, для отладки промптов вне GigaChat)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Backend
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# Хранилище
STORAGE_PATH=./data
LLM_LOG_PATH=./data/llm_logs

# CORS: дополнительный фронт-домен (например, https://your-app.vercel.app)
FRONTEND_ORIGIN=
